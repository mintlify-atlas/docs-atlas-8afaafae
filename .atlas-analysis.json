  "keyFeatures": [
    "70+ high-quality Vue 3 components matching Ant Design API",
    "Full TypeScript support with typed Props, Emits, and Slots",
    "CSS-in-JS theming via @antdv-next/cssinjs with design tokens",
    "Dark mode, compact mode, and custom algorithm support",
    "Internationalization for 70+ languages out of the box",
    "Tree-shakeable ES module build with auto-import resolver",
    "Server-side rendering (SSR) and Nuxt.js support",
    "Component-level token customization via ConfigProvider"
  ],
  "publicApiSurface": [
    "import AntdvNext from 'antdv-next'",
    "app.use(AntdvNext)",
    "import { Button, Input, Table, Form, ... } from 'antdv-next'",
    "import { theme } from 'antdv-next'",
    "theme.defaultAlgorithm / theme.darkAlgorithm / theme.compactAlgorithm",
    "theme.useToken()",
    "ConfigProvider :theme=\"{ token: {...}, algorithm: ... }\"",
    "ConfigProvider :locale=\"frFR\"",
    "useMessage() / useModal() / useNotification()",
    "import enUS from 'antdv-next/locale/en_US'",
    "AntdvNextResolver() for unplugin-vue-components",
    "StyleProvider (from @antdv-next/cssinjs)"
  ]
}
